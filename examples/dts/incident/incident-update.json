[
  {
    "id": 1,
    "type": "incident",
    "platform": "discord",
    "language": "en",
    "description": "Compact incident card (Kecleon, Gold Pokestop, Showcase, …) with location and expiry",
    "template": {
      "embed": {
        "title": "{{{incidentEmoji}}} {{incidentType}} at {{{pokestopName}}}",
        "url": "{{{googleMapUrl}}}",
        "color": "{{color}}",
        "thumbnail": {
          "url": "{{{imgUrl}}}"
        },
        "fields": [
          {
            "name": "Ends",
            "value": "{{disappearTime}} ({{#if tthh}}{{tthh}}h {{/if}}{{tthm}}m {{tths}}s)\n<t:{{expirationTimestamp}}:R>",
            "inline": true
          },
          {
            "name": "Weather",
            "value": "{{#if gameWeatherName}}{{gameWeatherEmoji}} {{gameWeatherName}}{{else}}—{{/if}}",
            "inline": true
          },
          {
            "name": "Location",
            "value": "[Google]({{{googleMapUrl}}}) | [Apple]({{{appleMapUrl}}}) | [Waze]({{{wazeMapUrl}}})\n{{{addr}}}",
            "inline": false
          }
        ],
        "image": {
          "url": "{{{staticMap}}}"
        }
      }
    }
  },
  {
    "id": 1,
    "type": "incident",
    "platform": "telegram",
    "language": "en",
    "description": "Compact incident card for Telegram",
    "template": {
      "content": "{{{incidentEmoji}}} *{{incidentType}}* at *{{{pokestopName}}}*\nEnds: {{disappearTime}} ({{#if tthh}}{{tthh}}h {{/if}}{{tthm}}m {{tths}}s)\nWeather: {{#if gameWeatherName}}{{gameWeatherEmoji}} {{gameWeatherName}}{{else}}—{{/if}}\n{{{addr}}}\n[Google]({{{googleMapUrl}}}) | [Apple]({{{appleMapUrl}}})",
      "sticker": "{{{stickerUrl}}}",
      "photo": "{{{staticMap}}}",
      "send_order": ["sticker", "text", "photo"],
      "parse_mode": "Markdown",
      "webpage_preview": false
    }
  }
]
