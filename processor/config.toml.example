[server]
host = "0.0.0.0"
port = 4200
ip_whitelist = ["127.0.0.1"]

[database]
dsn = "poracle:password@tcp(127.0.0.1:3306)/poracle?parseTime=true"

[alerter]
url = "http://localhost:4201"

[geofence]
paths = ["../alerter/config/geofence.json"]

[pvp]
pvp_query_max_rank = 100
pvp_filter_max_rank = 100
pvp_evolution_direct_tracking = true
level_caps = [50]
pvp_filter_great_min_cp = 1400
pvp_filter_ultra_min_cp = 2400
pvp_filter_little_min_cp = 400
include_mega_evolution = false

[weather]
enable_inference = true
enable_change_alert = true
show_altered_pokemon = true
show_altered_pokemon_max_count = 10
monsters_json_path = "../alerter/src/util/monsters.json"

# AccuWeather forecast - predicts next hour weather for boost change detection
enable_forecast = false
accuweather_api_keys = [""]
accuweather_day_quota = 50           # max API calls per key per day
forecast_refresh_interval = 8        # hours between API calls per cell
local_first_fetch_hod = 3            # first fetch hour of the day (e.g. 3 = 3am)
smart_forecast = false               # pull on demand if no data for a cell

[stats]
min_sample_size = 10000              # minimum sightings before calculating rarity
window_hours = 8                     # rolling window for rarity and shiny stats
refresh_interval_mins = 5            # how often to recalculate stats
rarity_group_2_uncommon = 1.0        # % of total sightings to be considered uncommon
rarity_group_3_rare = 0.5            # % rare
rarity_group_4_very_rare = 0.03      # % very rare
rarity_group_5_ultra_rare = 0.01     # % ultra rare

[tuning]
reload_interval_secs = 60
encounter_cache_ttl = 3600
worker_pool_size = 4
batch_size = 50
flush_interval_millis = 100

[areaSecurity]
enabled = false
strict_locations = false

[logging]
level = "info"
file_logging_enabled = true
filename = "logs/processor.log"
max_size = 50
max_age = 30
max_backups = 5
compress = false

[webhookLogging]
enabled = false
filename = "logs/webhooks.log"
max_size = 100
max_age = 1
max_backups = 3
compress = false
