{
    "style": "klokantech-basic",
    "latitude": {{ latitude }},
    "longitude": {{ longitude }},
    "zoom": {{ zoom }},
    "width": 500,
    "height": 250,
    "scale": 1,
    "markers": [
    {{ range i, point := points }}
        {{ if i != 0 }},{{ end }}
        {
            "url": "{{ if point.imgUrl }}{{ point.imgUrl }}{{ else }}https://raw.githubusercontent.com/nileplumb/PkmnShuffleMap/master/UICONS/pokestop/0.png{{ end }}",
            "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/pokestop.png",
            "latitude": {{ point.latitude }},
            "longitude": {{ point.longitude }},
            "width": 24,
            "height": 24,
            "y_offset": -12
        }
    {{ end }}
    ]
}
