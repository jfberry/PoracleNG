{
  "style": "klokantech-basic",
  "latitude": {{ latitude }},
  "longitude": {{ longitude }},
  "zoom": 11,
  "width": 500,
  "height": 250,
  "scale": 1,
  "markers": [
    {{ if isset(activePokemons) }}
     {{ range i, pok := activePokemons }}
     {
         "url": "{{ pok.imgUrl }}",
         "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/mon.png",
         "latitude": {{ pok.latitude }},
         "longitude": {{ pok.longitude }},
         "width": 20,
         "height": 20
     },
     {{ end }}
     {{ end }}
    {
      "url": "{{ imgUrl }}",
      "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/weather.png",
      "height": 40,
      "width": 40,
      "x_offset": 0,
      "y_offset": 0,
      "latitude": {{ latitude }},
      "longitude": {{ longitude }}
    }
  ]
  {{ if isset(coords) }}
  ,
  "polygons": [
    {
      "fill_color": "rgba(46,204,113,0.3)",
      "stroke_color": "rgba(46,204,113)",
      "stroke_width": 2,
      "path": [
        {{ range i, coord := coords }}
        {{ if i != 0 }},{{ end }}[{{ index(coord, 0) }}, {{ index(coord, 1) }}]
        {{ end }}
      ]
    }
  ]
  {{ end }}
}
