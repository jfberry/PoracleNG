{
    "grid": [
        {
            "direction": "first",
            "maps": [
                {
                    "direction": "first",
                    "map": {
                        "style": "klokantech-basic",
                        "latitude": {{ latitude }},
                        "longitude": {{ longitude }},
                        "zoom": 15,
                        "width": 350,
                        "height": 250,
                        "scale": 2,
                        "markers": [
                            {{ if isset(nearbyStops) }}
                                {{ range i, stop := nearbyStops }}
                                {
                                    "url": "{{ if stop.imgUrl }}{{ stop.imgUrl }}{{ else }}{{ uiconPokestopUrl }}{{ end }}",
                                    "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/{{ stop.type }}.png",
                                    "latitude": {{ stop.latitude }},
                                    "longitude": {{ stop.longitude }},
                                    "width": 20,
                                    "height": 20,
                                    "y_offset": -10
                                },
                                {{ end }}
                            {{ end }}
                            {
                                "url": "{{ imgUrl }}",
                                "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/mon.png",
                                "latitude": {{ latitude }},
                                "longitude": {{ longitude }},
                                "width": 20,
                                "height": 20
                            }
                        ],
    {{ if seenType == "cell" }}
                        "polygons": [
                            {
                                "fill_color": "rgba(255,255,255,0.6)",
                                "stroke_color": "#C7C7C7",
                                "stroke_width": 1,
                                "path":
                                [
                                    {{ range i, coord := cell_coords }}
                                        {{ if i != 0 }},{{ end }}[{{ index(coord, 0) }}, {{ index(coord, 1) }}]
                                    {{ end }}
                                ]
                            }
                        ]
    {{ else }}
                        "circles": [
                            {
                                "fill_color": "rgba(255,255,255,0.6)",
                                "stroke_color": "#C7C7C7",
                                "stroke_width": 1,
                                "latitude": {{ latitude }},
                                "longitude": {{ longitude }},
                                "radius": 40
                            }
                        ]
    {{ end }}
                    }
                },
                {
                    "direction": "right",
                    "map": {
                        "style": "mapbox-sattelite",
                        "latitude": {{ latitude }},
                        "longitude": {{ longitude }},
                        "zoom": 18,
                        "width": 400,
                        "height": 500,
                        "scale": 1,
                        "markers": [
                            {
                                "url": "{{ imgUrl }}",
                                "fallback_url": "https://raw.githubusercontent.com/KartulUdus/PoracleJS/images/fallback/mon.png",
                                "latitude": {{ latitude }},
                                "longitude": {{ longitude }},
                                "width": 60,
                                "height": 60
                            }
                        ],
                        "circles": [
                            {
                                "fill_color": "rgba(255,255,255,0.4)",
                                "stroke_color": "rgba(255,255,255,0.25)",
                                "stroke_width": 1,
                                "latitude": {{ latitude }},
                                "longitude": {{ longitude }},
                                "radius": 40
                            }
                        ]
                    }
                }
            ]
        }
    ]
}
